PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/vistaprint-clone
NODE_ENV=development
USE_MOCK_DATA=false

# ============================================
# 4over API Configuration
# ============================================
# Get these credentials from your 4over reseller dashboard
# Contact 4over support for API access: https://4over.com
#
# Steps to get credentials:
# 1. Create reseller account at https://4over.com
# 2. Submit reseller certificate for verification
# 3. Once approved, contact support for API access
# 4. Get your Account ID, API Key, and API Secret
# ============================================

FOUROVER_API_KEY=your_api_key_here
FOUROVER_API_SECRET=your_api_secret_here
FOUROVER_ACCOUNT_ID=your_account_id_here
FOUROVER_RESELLER_ID=your_reseller_id_here
FOUROVER_BASE_URL=https://api.4over.com

# Your profit margin percentage (e.g., 30 = 30% markup on 4over prices)
FOUROVER_MARKUP_PERCENT=30
